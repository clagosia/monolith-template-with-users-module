# Database (PostgreSQL - used when USE_MOCK_DB is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=monolith_template

# Mock Database (SQLite - set USE_MOCK_DB=true to use instead of PostgreSQL)
# USE_MOCK_DB=true
# MOCK_DB_PATH=./mock.sqlite

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=3600

# App
APP_PORT=3000
